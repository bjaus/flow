# Copy to .env (git-ignored) and fill in. The runtime reads secrets from the environment only.

# Local OpenAI-compatible model gateway used by the default provider.
FLOW_GATEWAY_URL=http://localhost:4000/v1
FLOW_GATEWAY_KEY=

# Note: upstream model-provider API keys live in the gateway's own config, not here.

# Optional observability (§6.5). Leave unset for the no-op default. Set an OTLP endpoint to export traces to
# Arize Phoenix, Langfuse, or any OpenTelemetry backend (standard OTel env vars).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces   # e.g. a local Phoenix
# OTEL_EXPORTER_OTLP_HEADERS=
